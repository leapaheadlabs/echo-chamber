# ── ECHO CHAMBER — Environment Configuration ──────────────────────────────
# Copy to .env and fill in your values.
# NEVER commit a populated .env file.

# ── Core ───────────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
CORTEX_PORT=8000

# ── Database ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://echo:echo_dev@localhost:5432/echo_chamber
DB_PASSWORD=echo_dev
DB_PORT=5432
REDIS_URL=redis://localhost:6379/0
REDIS_PORT=6379

# ── LLM Providers (at least one required) ──────────────────────────────────
OPENAI_API_KEY=sk-your-key-here
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Platform APIs ──────────────────────────────────────────────────────────
# Reddit (required for Reddit Ganglion)
REDDIT_CLIENT_ID=your-client-id
REDDIT_CLIENT_SECRET=your-client-secret
REDDIT_USER_AGENT=echo-chamber/0.1.0

# Discord (required for Commander and Discord Ganglion)
DISCORD_BOT_TOKEN=your-bot-token
DISCORD_COMMANDER_GUILD_ID=your-guild-id

# ── Optional ───────────────────────────────────────────────────────────────
# LangSmith / LangFuse (tracing)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=echo-chamber

# Proxy (for account pool rotation)
PROXY_PROVIDER_URL=
PROXY_API_KEY=

# Encryption (for credential vault)
VAULT_ENCRYPTION_KEY=  # Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"